# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funnel_radar?schema=public"

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Worker / Scheduler
WORKER_ENABLED="false"
SCHEDULER_INTERVAL_HOURS="6"

# Discovery limits
DISCOVERY_BATCH_SIZE="30"
DEEP_AUDIT_LIMIT="8"
DEMO_GENERATION_LIMIT="3"

# QA / Scoring
QA_MAX_ITERATIONS="3"
MIN_LEAD_SCORE="75"
MIN_DEMO_SCORE="80"

# LLM provider mode (rule_based_only | manual_composer_assisted | future_api_llm)
LLM_PROVIDER="rule_based_only"

# Optional: LLM API keys (unused in rule_based_only mode)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Optional model id for Claude → Stitch Prompt Agent (defaults to claude-sonnet-4-20250514)
ANTHROPIC_MODEL=""

# Discovery sources (none required for v1; toggles for future)
ENABLE_SERP_SOURCE="false"
ENABLE_DIRECTORY_SOURCES="false"
# HTML search research (DuckDuckGo public HTML — no API key). Pair with ENABLE_STUB_DISCOVERY=false for real-only runs.
ENABLE_WEB_RESEARCH_SOURCE="false"
ENABLE_STUB_DISCOVERY="true"

# Google Places API (New) — text search from the server. Restrict key by IP in prod.
GOOGLE_MAPS_API_KEY=""
ENABLE_GOOGLE_PLACES_SOURCE="false"

# After each demo-generation job: design brief + DESIGN.md + internal variants, optional merge/Stitch (see below).
# Set true so "Generate demo" on a business runs this pipeline in-process when the demo-generation job finishes.
AUTOMATE_DESIGN_WORKFLOW="false"
AUTO_SELECT_BEST_DESIGN_VARIANT="true"

# Google Stitch (Labs) — @google/stitch-sdk (server). Reference import only; production renderer unchanged.
# For automatic Stitch on each new demo: AUTOMATE_DESIGN_WORKFLOW="true" AND ENABLE_STITCH_SDK="true" AND STITCH_API_KEY set.
# Or leave AUTOMATE_DESIGN_WORKFLOW false and use the business page → Design workflow → "Run Stitch SDK → import variant".
STITCH_API_KEY=""
ENABLE_STITCH_SDK="false"
# Minimum stitchPromptScore (0–100) before automated Stitch SDK runs after prompt agent
STITCH_PROMPT_MIN_AUTO_SCORE="88"
# STITCH_HOST=""  # optional; SDK default if unset
