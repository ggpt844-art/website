# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funnel_radar?schema=public"

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Worker / Scheduler
WORKER_ENABLED="false"
SCHEDULER_INTERVAL_HOURS="6"

# Discovery limits
DISCOVERY_BATCH_SIZE="30"
DEEP_AUDIT_LIMIT="8"
DEMO_GENERATION_LIMIT="3"

# QA / Scoring
QA_MAX_ITERATIONS="3"
MIN_LEAD_SCORE="75"
MIN_DEMO_SCORE="88"

# LLM provider mode (rule_based_only | manual_composer_assisted | future_api_llm)
LLM_PROVIDER="rule_based_only"

# Optional: LLM API keys (unused in rule_based_only mode)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Discovery sources (none required for v1; toggles for future)
ENABLE_SERP_SOURCE="false"
ENABLE_DIRECTORY_SOURCES="false"
