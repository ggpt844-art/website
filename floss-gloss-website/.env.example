# Copy to `.env.local` (never commit). Keys in chat should be rotated in Google Cloud.

# Reviews: accepts either name below (same key works for Place Details if Places API is enabled).
GOOGLE_MAPS_API_KEY=
# GOOGLE_PLACES_API_KEY=

# Set to true | 1 | yes to fetch live reviews (default if unset). false | 0 | off | no skips API.
ENABLE_GOOGLE_PLACES_SOURCE=true

# Optional — defaults to Floss & Gloss (Mississauga) in code. Set for another listing.
# https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# Optional: bump hero image cache (see components/Hero.tsx)
# NEXT_PUBLIC_HERO_BUST=
